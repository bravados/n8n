# =============================================================================
#  .env  —  variables del stack de n8n
#  Copia este archivo como ".env" (sin .example) junto al docker-compose.yml
#  y rellena los valores. NO lo subas a git.
# =============================================================================

# --- Postgres de n8n ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CAMBIA_ESTO_por_una_password_larga
POSTGRES_DB=n8n

# --- Dominio público de n8n (el que apunta tu reverse proxy) ---
# Ej: n8n.tudominio.com   -> esta es la base de la URL de webhook de YCloud
N8N_HOST=n8n.tudominio.com

# --- Clave de cifrado de credenciales ---
# Genérala UNA sola vez con:   openssl rand -hex 32
# Guárdala a buen recaudo. Si la pierdes/cambias, n8n no podrá descifrar
# las credenciales ya guardadas.
N8N_ENCRYPTION_KEY=pega_aqui_el_resultado_de_openssl_rand_hex_32

# --- Acceso al editor de n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CAMBIA_ESTO_tambien
